// Password hashing utility — works in both local (localStorage) and live
// (MySQL) modes. The hash is produced client-side with Web Crypto PBKDF2
// (SHA-256, 100k iterations, random 16-byte salt) and stored as a string:
//   pbkdf2$<iterations>$<saltHex>$<hashHex>
// PHP stores/returns this string verbatim; verification is done in the
// browser. Legacy plaintext passwords (e.g. the seeded admin) are still
// accepted via a fallback so accounts aren't locked out during migration.

const ITER = 100000;
const KEY_LEN = 32;

const bufToHex = (buf) =>
  Array.from(new Uint8Array(buf))
    .map((b) => b.toString(16).padStart(2, "0"))
    .join("");

const hexToBuf = (hex) => {
  const arr = new Uint8Array(hex.length / 2);
  for (let i = 0; i < hex.length; i += 2)
    arr[i / 2] = parseInt(hex.substr(i, 2), 16);
  return arr;
};

const derive = async (plain, saltHex) => {
  const enc = new TextEncoder();
  const keyMaterial = await crypto.subtle.importKey(
    "raw",
    enc.encode(plain),
    "PBKDF2",
    false,
    ["deriveBits"]
  );
  const bits = await crypto.subtle.deriveBits(
    { name: "PBKDF2", salt: hexToBuf(saltHex), iterations: ITER, hash: "SHA-256" },
    keyMaterial,
    KEY_LEN * 8
  );
  return bufToHex(bits);
};

export async function hashPassword(plain) {
  const salt = crypto.getRandomValues(new Uint8Array(16));
  const saltHex = bufToHex(salt);
  const hash = await derive(plain, saltHex);
  return `pbkdf2$${ITER}$${saltHex}$${hash}`;
}

export async function verifyPassword(plain, stored) {
  if (!stored) return false;
  // Legacy plaintext (no PBKDF2 marker) — direct compare for migration.
  if (!stored.startsWith("pbkdf2$")) return plain === stored;
  const parts = stored.split("$");
  if (parts.length !== 4) return false;
  const saltHex = parts[2];
  const hash = parts[3];
  const calc = await derive(plain, saltHex);
  return calc === hash;
}